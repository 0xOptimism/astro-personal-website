---
const title = "Yannis";
const role = "Full-stack developer";
const description = "I build production web apps across frontend, backend, and mobile, mostly with TypeScript, React, Node.js, and agentic workflows.";
const proofPoints = [
  "5+ years shipping product",
  "Medtech, e-commerce, Web3",
  "ETH Denver 2023 winner",
  "Antibes-born, Stockholm-based"
];
---

<div class="font-display">
  <p class="reveal text-(--color-text-muted) text-sm uppercase tracking-[0.2em]">
    Hey, I'm
  </p>
  <h1 class="reveal reveal-delay-1 mt-2 text-5xl font-extrabold tracking-tight sm:text-6xl md:text-7xl lg:text-8xl">
    {title}
  </h1>
  <p class="reveal reveal-delay-2 mt-3 text-2xl font-medium text-(--color-accent) sm:text-3xl md:text-4xl">
    {role}
  </p>
  <p class="reveal reveal-delay-3 mt-8 max-w-xl font-body text-lg font-normal leading-relaxed text-(--color-text-muted)">
    {description}
  </p>
  <div class="reveal reveal-delay-4 mt-8 flex max-w-2xl flex-wrap gap-2">
    {
      proofPoints.map((point) => (
        <span class="rounded-md border border-(--color-surface-elevated) bg-(--color-surface) px-3 py-2 font-body text-sm text-(--color-text-muted)">
          {point}
        </span>
      ))
    }
  </div>
</div>
